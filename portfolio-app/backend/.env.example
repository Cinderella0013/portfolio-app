# ---------- ฐานข้อมูล ----------
# ใช้ Postgres ที่ไหนก็ได้ เช่น Neon, Supabase, Railway หรือ docker-compose ในโปรเจกต์นี้
DATABASE_URL="postgresql://portfolio:portfolio@localhost:5432/portfolio?schema=public"

# ---------- เซิร์ฟเวอร์ ----------
PORT=4000
NODE_ENV=development

# ---------- ความปลอดภัย ----------
# สร้างค่าใหม่ด้วย: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="เปลี่ยนค่านี้ก่อนขึ้นจริง"
JWT_EXPIRES_IN="7d"

# โดเมนหน้าบ้านที่อนุญาตให้เรียก API คั่นด้วยจุลภาค
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# ---------- บัญชีแอดมินตัวแรก (ใช้ตอน seed) ----------
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="เปลี่ยนรหัสนี้ด้วย"
ADMIN_NAME="ชื่อของคุณ"
