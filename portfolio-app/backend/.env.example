# ---------- ฐานข้อมูล ----------
# ใช้ Postgres ที่ไหนก็ได้ เช่น Neon, Supabase, Railway หรือ docker-compose ในโปรเจกต์นี้
DATABASE_URL="postgresql://portfolio:portfolio@localhost:5432/portfolio?schema=public"

# ---------- เซิร์ฟเวอร์ ----------
PORT=4000
NODE_ENV=development

# ---------- ความปลอดภัย ----------
# สร้างค่าใหม่ด้วย: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="เปลี่ยนค่านี้ก่อนขึ้นจริง"
JWT_EXPIRES_IN="7d"

# โดเมนหน้าบ้านที่อนุญาตให้เรียก API คั่นด้วยจุลภาค
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# ---------- บัญชีแอดมินตัวแรก (ใช้ตอน seed) ----------
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="เปลี่ยนรหัสนี้ด้วย"
ADMIN_NAME="ชื่อของคุณ"

# ---------- ระบบย่อลิงก์ (Google Sheets) — เว้นว่างได้ ฟีเจอร์จะปิดตัวเอง ----------
# 1) สร้าง Service Account ใน Google Cloud Console แล้วเปิดใช้ Google Sheets API
# 2) สร้าง key แบบ JSON แล้วเอาค่า client_email กับ private_key มาใส่
# 3) สร้าง Google Sheet เปล่า แชร์ให้อีเมล service account (สิทธิ์ Editor)
#    แล้วเอา id จาก URL ของชีตมาใส่ SHEETS_ID (แท็บ links ระบบสร้างให้เอง)
# หมายเหตุ: private_key ต้องคงรูป \n ไว้ตามใน JSON (ไม่ต้องแปลงเป็นขึ้นบรรทัดจริง)
GOOGLE_SA_EMAIL=""
GOOGLE_SA_KEY=""
SHEETS_ID=""

# ---------- แชทบอท (OpenAI-compatible) — เว้น CHATBOT_API_KEY ว่างได้ ฟีเจอร์จะปิดตัวเอง ----------
# ใช้ endpoint แบบ OpenAI ที่ไหนก็ได้ เช่น Gen AI KKU, OpenAI, OpenRouter
CHATBOT_API_KEY=""
CHATBOT_BASE_URL="https://gen.ai.kku.ac.th/api/v1"
CHATBOT_MODEL="gemini-3.5-flash-lite"
